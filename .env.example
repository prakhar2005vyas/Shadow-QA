# Shadow QA — environment variables
# Copy this to .env and fill in your values. Never commit .env.

# ---------- VLM / Vision-Decision layer (AMD vLLM on MI300X) ----------
# These are ONLY used for the vision/decision step (Gemma 4 on AMD hardware).
MOCK_VLM=true
VLM_BASE_URL=http://<droplet-ip>:8000/v1
VLM_MODEL_ID=google/gemma-4-26B-A4B-it
VLM_API_KEY=changeme

# ---------- Fireworks AI (report-writing step ONLY) ----------
# Fireworks is NEVER used for vision/decision — only for writing polished bug reports.
FIREWORKS_API_KEY=
FIREWORKS_MODEL_ID=accounts/fireworks/models/llama-v3p3-70b-instruct

# ---------- Agent budget ----------
MAX_STEPS_PER_RUN=20
MAX_SECONDS_PER_RUN=240

# ---------- Database ----------
DATABASE_URL=sqlite:///./shadowqa.db
